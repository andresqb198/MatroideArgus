# Meridian Configuration
# Copy to .env and fill in values

# Backend
MERIDIAN_DATABASE_URL=postgresql+asyncpg://meridian:meridian@localhost:5432/meridian
MERIDIAN_CLICKHOUSE_HOST=localhost
MERIDIAN_CLICKHOUSE_PORT=8123
MERIDIAN_SECRET_KEY=change-me-in-production
MERIDIAN_ENVIRONMENT=development

# Auth0
MERIDIAN_AUTH0_DOMAIN=
MERIDIAN_AUTH0_API_AUDIENCE=

# SDK
MERIDIAN_API_KEY=
MERIDIAN_API_URL=http://localhost:8000
MERIDIAN_PROJECT=
MERIDIAN_ENV=development
